# =============================================================
# ATRIO · Variables de entorno
# Copiar a .env.local y completar. Nunca commitear .env.local.
# =============================================================

# --- Supabase (proyecto "atrio" en didigitalstudio · sa-east-1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Mapbox (no usado todavía — se activa con la búsqueda en mapa) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Resend (mails transaccionales: leads, tasaciones, submissions, approvals) ---
# Sin RESEND_API_KEY los avisos se loguean y se saltean (no rompen la operación).
RESEND_API_KEY=
# Sender por defecto. Hasta verificar dominio, "Atrio <onboarding@resend.dev>"
# (sandbox de Resend, solo manda al email registrado en su cuenta).
# Después de verificar dominio: "Atrio <noreply@atrio.com.ar>".
RESEND_FROM=
# Email del equipo Atrio que recibe los avisos cuando no hay agente asignado.
NOTIFICATIONS_EMAIL=
# URL pública (para links absolutos en los mails).
NEXT_PUBLIC_SITE_URL=https://atrio-omega.vercel.app
